/* pages/login/login.wxss — 登录页 */
page { background-color: #FFFFFF; height: 100vh; }

.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 0 32rpx;
}

/* 关闭按钮 */
.login-close {
  position: fixed; top: 64rpx; right: 32rpx;
  width: 60rpx; height: 60rpx;
  display: flex; align-items: center; justify-content: center;
  color: #999; font-size: 36rpx;
  z-index: 10;
}

/* 品牌区（约25%位置） */
.login-brand {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.login-logo {
  width: 320rpx;
  height: 320rpx;
  border-radius: 16rpx;
  margin-bottom: 0;
}

.login-name {
  display: none;
  font-size: 48rpx;
  font-weight: 800;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.login-slogan {
  font-size: 24rpx;
  color: #8A4DFF;
  margin-top: -12rpx;
  margin-bottom: 60rpx;
}

/* 登录按钮区 */
.login-btn-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.login-btn {
  width: 580rpx;
  max-width: 580rpx;
  height: 72rpx;
  line-height: 72rpx;
  box-sizing: border-box;
  background: linear-gradient(135deg, #8A4DFF, #7C4DFF);
  border-radius: 46rpx;
  color: #FFFFFF;
  font-size: 34rpx;
  font-weight: 700;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  margin-bottom: 20rpx;
  padding: 0 32rpx;
  box-shadow: 0 8rpx 32rpx rgba(138, 77, 255, 0.35);
  border: none;
}

.login-btn::after { border: none; }

.login-btn-icon { font-size: 38rpx; }

.login-btn-inner {
  width: 100%;
  height: 100%;
  background: transparent;
  color: #FFFFFF;
  font-size: 34rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 0;
  margin: 0;
  border: none;
  line-height: 1;
}

.login-btn-inner::after { border: none; }

/* 其他登录方式 */
.login-other-btn {
  width: 580rpx;
  max-width: 580rpx;
  height: 72rpx;
  line-height: 72rpx;
  background: rgba(138, 77, 255, 0.08);
  border: none;
  border-radius: 42rpx;
  color: #8A4DFF;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  margin-bottom: 40rpx;
  padding: 0 32rpx;
}

/* 协议区（双行居中） */
.login-agreement {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  margin-top: 16rpx;
  margin-bottom: 16rpx;
}

.login-agree-title {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
  text-align: center;
}

.login-agree-links {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
}

.agree-dot {
  color: #999;
  margin: 0 6rpx;
}

.login-skip {
  font-size: 26rpx;
  color: #999;
  text-decoration: underline;
  padding: 12rpx 24rpx;
  margin-bottom: 64rpx;
}

.agreement-link {
  color: #8A4DFF;
  margin: 0 2rpx;
}
