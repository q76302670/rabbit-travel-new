<!-- pages/login/login.wxml — 登录页 -->
<view class="login-page">
  <!-- 关闭按钮 -->
  <view class="login-close" bindtap="closeLogin">
    <text>✕</text>
  </view>

  <!-- 品牌区 -->
  <view class="login-brand">
    <image class="login-logo" src="../../images/logo.png" mode="aspectFit" />
    <text class="login-name">兔子旅行</text>
    <text class="login-slogan">记录每一段旅行</text>
  </view>

  <!-- 登录按钮区 -->
  <view class="login-btn-area">
    <view class="login-btn">
      <button class="login-btn-inner" bindgetuserinfo="onGetUserInfo" open-type="getUserInfo">
        <text class="login-btn-icon">💬</text>
        <text>微信一键登录</text>
      </button>
    </view>

    <!-- 其他登录方式 -->
    <view class="login-other-btn" bindtap="onOtherLogin">
      <text>其他登录方式</text>
    </view>

    <!-- 协议区（双行居中） -->
    <view class="login-agreement">
      <view class="login-agree-title">我已阅读并同意</view>
      <view class="login-agree-links">
        <text class="agreement-link" bindtap="openAgreement">服务协议</text>
        <text class="agree-dot"> · </text>
        <text class="agreement-link" bindtap="openPrivacy">隐私政策</text>
        <text class="agree-dot"> · </text>
        <text class="agreement-link" bindtap="openChildren">儿童协议</text>
      </view>
    </view>

    <text class="login-skip" bindtap="skipLogin">先逛逛</text>
  </view>
</view>
