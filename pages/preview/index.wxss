/* pages/preview/index.wxss — 发布预览 */
page { background: #F8F7FC; }

/* 封面 */
.pv-cover { position: relative; width: 100%; height: 360rpx; overflow: hidden; }
.pv-cover-img { width: 100%; height: 100%; object-fit: cover; }
.pv-cover-placeholder { width: 100%; height: 100%; background: #F5F0FF; display: flex; align-items: center; justify-content: center; font-size: 60rpx; }
.pv-cover-grad { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%); pointer-events: none; }
.pv-cover-back { position: absolute; left: 24rpx; width: 60rpx; height: 60rpx; background: rgba(0,0,0,0.3); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FFF; font-size: 36rpx; z-index: 10; }
.pv-cover-info { position: absolute; bottom: 32rpx; left: 24rpx; right: 24rpx; }
.pv-cover-title { font-size: 40rpx; font-weight: 800; color: #FFF; text-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3); display: block; margin-bottom: 12rpx; }
.pv-cover-author { display: flex; align-items: center; gap: 12rpx; }
.pv-avatar { width: 48rpx; height: 48rpx; border-radius: 50%; }
.pv-avatar-placeholder { width: 48rpx; height: 48rpx; border-radius: 50%; background: rgba(255,255,255,0.3); display: flex; align-items: center; justify-content: center; font-size: 24rpx; }
.pv-nickname { font-size: 24rpx; color: rgba(255,255,255,0.9); }

/* 正文 */
.pv-body { padding: 32rpx 24rpx; }

/* 元信息 */
.pv-meta { display: flex; flex-wrap: wrap; gap: 16rpx; margin-bottom: 24rpx; padding-bottom: 20rpx; border-bottom: 1rpx solid #E8E8E8; }
.pv-meta-item { font-size: 24rpx; color: #666; }

/* 说明 */
.pv-intro { background: #FFF; padding: 24rpx; border-radius: 16rpx; margin-bottom: 24rpx; font-size: 26rpx; color: #333; line-height: 1.6; }

/* 时间线 */
.pv-timeline { position: relative; padding-left: 32rpx; }
.pv-tl-node { position: relative; margin-bottom: 32rpx; }
.pv-tl-dot { position: absolute; left: -36rpx; top: 16rpx; width: 16rpx; height: 16rpx; background: #8A4DFF; border-radius: 50%; border: 3rpx solid #FFF; box-shadow: 0 0 0 1rpx #E0D8FF; }
.pv-tl-card { background: #FFF; border-radius: 16rpx; overflow: hidden; }
.pv-tl-img { width: 100%; display: block; }
.pv-tl-img-placeholder { width: 100%; aspect-ratio: 16/9; background: #F5F0FF; display: flex; align-items: center; justify-content: center; font-size: 48rpx; color: #8A4DFF; }
.pv-tl-desc { display: block; padding: 16rpx 20rpx; font-size: 24rpx; color: #555; line-height: 1.5; }

/* 底部标签 */
.pv-footer { position: fixed; bottom: 0; left: 0; right: 0; text-align: center; padding: 16rpx 0; padding-bottom: calc(16rpx + env(safe-area-inset-bottom)); background: rgba(138,77,255,0.08); }
.pv-footer-text { font-size: 22rpx; color: #8A4DFF; }

/* 加载状态 */
.pv-loading { text-align: center; padding: 120rpx 0; color: #999; }
