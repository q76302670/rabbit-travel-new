/* pages/edit-profile/index.wxss — 编辑资料（渐变头部） */
.edit-profile-page {
  min-height: 100vh;
  background: #FDF7FF;
  padding-bottom: 200rpx;
}

/* ======== 渐变头部（导航栏 + 头像区） ======== */
.edit-profile-header {
  background: linear-gradient(180deg, #7C4DFF 0%, #9C6FFF 100%);
  box-sizing: content-box;
}

/* ======== 导航栏（flow in header，不再 fixed） ======== */
.page-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 32rpx;
}

.nav-cancel, .nav-save {
  color: #FFFFFF;
  font-size: 28rpx;
  flex-shrink: 0;
}

.nav-save {
  font-weight: 700;
}

.nav-title {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
}

/* ======== 内容区 ======== */
.content-wrap {
  height: calc(100vh - 88rpx);
  box-sizing: border-box;
}

/* ======== 头像区（在渐变头部内） ======== */
.avatar-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0 40rpx;
}

.avatar-circle {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.8);
  overflow: visible;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  object-fit: cover;
  display: block;
}

.avatar-image-empty {
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.avatar-edit-icon {
  position: absolute;
  bottom: -6rpx;
  right: -6rpx;
  width: 48rpx;
  height: 48rpx;
  background: #FFFFFF;
  border: 2rpx solid #8A4DFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-edit-svg {
  width: 24rpx;
  height: 24rpx;
}

.avatar-hint {
  color: rgba(255,255,255,0.8);
  font-size: 24rpx;
  margin-top: 16rpx;
}

/* ======== 表单卡片 ======== */
.form-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 24rpx;
  margin: 16rpx 32rpx;
}

.field-label {
  display: block;
  color: #1A1A1A;
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.field-input {
  width: 100%;
  font-size: 32rpx;
  font-weight: 700;
  color: #1A1A1A;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  background: transparent;
}

.field-textarea {
  width: 100%;
  font-size: 28rpx;
  color: #1A1A1A;
  min-height: 200rpx;
  padding: 8rpx 0;
  background: transparent;
  border: none;
  line-height: 1.6;
}

.field-count {
  text-align: right;
  color: #999;
  font-size: 22rpx;
  display: block;
  margin-top: 8rpx;
}

/* ======== 旅行偏好标签 ======== */
.tags-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.tags-count {
  color: #999;
  font-size: 22rpx;
}

.tags-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  background: #F5F0FF;
  color: #8A4DFF;
  border: 2rpx solid #8A4DFF;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.tag-item.selected {
  background: #8A4DFF;
  color: #FFFFFF;
}

.tag-check {
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
}

/* ======== 底部确认按钮 ======== */
.confirm-btn-wrap {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(253,247,255,0.95);
  z-index: 100;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: #8A4DFF;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  line-height: 96rpx;
}

.confirm-btn::after {
  border: none;
}
