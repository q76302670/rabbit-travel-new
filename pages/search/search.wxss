/* pages/search/search.wxss — 搜索页（Stitch 视觉还原） */
page { background-color: #FFFFFF; }

.search-header {
  display: flex; align-items: center; padding: 8px 16px; gap: 10px;
  background: #8A4DFF; box-sizing: content-box;
}
.search-box {
  flex: 1; display: flex; align-items: center; height: 36px;
  padding: 0 12px; background: rgba(255,255,255,0.2); border-radius: 24px; gap: 8px;
}
.search-icon { font-size: 14px; color: rgba(255,255,255,0.8); }
.search-input { flex: 1; font-size: 14px; color: #FFFFFF; }
.search-input::placeholder { color: rgba(255,255,255,0.6); }
.search-clear { font-size: 14px; color: rgba(255,255,255,0.7); padding: 4px; }
.search-cancel { font-size: 14px; color: #FFFFFF; padding: 4px 0; }

.search-body { padding: 16px; padding-bottom: calc(16px + env(safe-area-inset-bottom)); }
.search-hint, .search-empty { text-align: center; padding: 60px 0; color: #999; font-size: 14px; }

.result-item {
  display: flex; gap: 12px; padding: 12px 0; border-bottom: 1px solid #F0F0F0;
}
.result-cover { width: 72px; height: 72px; border-radius: 8px; flex-shrink: 0; background: #F5F0FF; }
.result-info { flex: 1; display: flex; flex-direction: column; justify-content: center; }
.result-title { font-size: 14px; font-weight: 700; color: #1A1A1A; }
.result-author { font-size: 12px; color: #999; margin-top: 4px; }
