<!-- pages/search/search.wxml -->
<view class="search-page">
  <view class="search-header" style="padding-top: {{statusBarHeight}}px;">
    <view class="search-nav-inner" style="padding-right: {{navPaddingRight}}px;">
      <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        placeholder="搜索目的地或游记标题"
        value="{{keyword}}"
        bindinput="onKeywordInput"
        bindconfirm="onSearch"
        focus
      />
      <text wx:if="{{keyword}}" class="search-clear" bindtap="clearKeyword">✕</text>
    </view>
    <text class="search-cancel" bindtap="goBack">取消</text>
    </view>
  </view>

  <view class="search-body">
    <!-- 未搜索 -->
    <view wx:if="{{!hasSearched}}" class="search-hint">
      <text>输入关键词开始搜索</text>
    </view>

    <!-- 无结果 -->
    <view wx:elif="{{results.length === 0}}" class="search-empty">
      <text>未找到相关游记</text>
    </view>

    <!-- 结果列表 -->
    <view
      class="result-item"
      wx:for="{{results}}"
      wx:key="_id"
      data-id="{{item._id}}"
      bindtap="goToDetail"
    >
      <image class="result-cover" src="{{item.cover}}" mode="aspectFill" binderror="handleImageError" data-id="{{item._id}}" data-imgfield="cover" data-imglist="results" data-imgidfield="_id" wx:if="{{item.cover}}" />
      <view class="result-info">
        <text class="result-title">{{item.title}}</text>
        <text class="result-author">{{item.author_name || '旅行者'}}</text>
      </view>
    </view>
  </view>
</view>
