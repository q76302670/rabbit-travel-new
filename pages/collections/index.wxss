/* pages/collections/index.wxss — 我的收藏（Stitch ⭐ 原型） */
page { background-color: #F5F0FF; }

/* ======== 导航栏 ======== */
.page-header {
  display: flex; align-items: center;
  height: 44px; box-sizing: content-box;
  padding-left: 16px; padding-right: 16px; background: #8A4DFF;
}
.header-left { display: flex; align-items: center; gap: 8px; }
.header-title { font-size: 18px; font-weight: 700; color: #FFFFFF; }
.nav-back { display: flex; align-items: center; justify-content: center; padding: 8rpx; }
.back-icon { font-size: 40rpx; color: #FFFFFF; width: 36rpx; height: 36rpx; display: flex; align-items: center; justify-content: center; }

/* 搜索条 */
.collect-search-bar {
  margin: 16rpx 32rpx;
  background: #F5F0FF;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.collect-search-icon { font-size: 26rpx; flex-shrink: 0; }
.search-input { flex: 1; font-size: 26rpx; color: #1A1A1A; }
.search-placeholder { color: #999; }
.search-clear {
  width: 32rpx; height: 32rpx; border-radius: 50%;
  background: #ccc; color: #fff; font-size: 22rpx;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}

/* ======== 正文 ======== */
.likes-body { padding: 0 16px 16px; padding-bottom: calc(16px + env(safe-area-inset-bottom)); }

/* ======== 统计行 ======== */
.stats-row {
  padding: 16px 0 12px;
  display: flex; align-items: baseline; gap: 6px;
}
.stats-num {
  font-size: 28px; font-weight: 700; color: #8A4DFF; line-height: 1;
}
.stats-label {
  font-size: 14px; color: #666666; line-height: 1;
}

/* ======== 空态 ======== */
.list-empty { text-align: center; padding: 80px 0; color: #B0A0D0; font-size: 14px; }

/* ======== 双列瀑布流 ======== */
.card-grid {
  display: flex; gap: 12px;
}

.card-col {
  flex: 1; display: flex; flex-direction: column; gap: 12px;
}

.card-item {
  background: #FFFFFF;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0,0,0,0.06);
}

.card-cover-wrap { position: relative; overflow: hidden; }
.card-cover { width: 100%; display: block; border-radius: 12px 12px 0 0; }
.card-cover-empty { width: 100%; height: 120px; background: #F0E8F8; }
.card-save-icon {
  position: absolute; top: 8px; right: 8px;
  width: 28px; height: 28px;
  background: rgba(255,255,255,0.7);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
}

.card-title {
  display: block; padding: 10px 12px 4px;
  font-size: 14px; font-weight: 700; color: #1A1A1A;
  line-height: 1.4;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}

.card-author {
  display: flex; align-items: center; gap: 6px;
  padding: 4px 12px 12px;
}
.card-avatar { width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0; }
.card-avatar-empty { width: 24px; height: 24px; border-radius: 50%; background: #F0E8F8; flex-shrink: 0; }
.card-name { font-size: 12px; color: #666666; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.card-likes { font-size: 12px; color: #8A4DFF; flex-shrink: 0; }
