/* pages/follow-list/index.wxss — 粉丝/关注通用列表 */
.follow-list-page {
  min-height: 100vh;
  background: #FDF7FF;
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  background: #8A4DFF;
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  height: 88rpx;
  z-index: 100;
}

.nav-back {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  width: 40rpx;
  height: 40rpx;
}

.nav-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  flex: 1;
  text-align: center;
  margin-right: 64rpx;
}

.user-list {
  padding: 16rpx 32rpx;
}

.user-item {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  flex: none;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1A1A;
  display: block;
  margin-bottom: 8rpx;
}

.user-bio {
  font-size: 24rpx;
  color: #999;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 32rpx;
}

.empty-icon-text {
  font-size: 80rpx;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #999;
}
