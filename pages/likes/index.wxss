/* pages/likes/index.wxss — 我的点赞（新 zip 风格） */
page {
  background-color: #FFFFFF;
}

/* ======== 导航栏 ======== */
.page-header {
  display: flex; align-items: center;
  height: 44px; box-sizing: content-box;
  padding-left: 16px; background: #8A4DFF;
}
.header-left { display: flex; align-items: center; gap: 8px; }
.header-back { font-size: 20px; color: #FFFFFF; line-height: 1; }
.header-title { font-size: 18px; font-weight: 700; color: #FFFFFF; }

/* ======== 正文 ======== */
.likes-body {
  padding: 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
}

/* ======== 统计卡片 ======== */
.stats-card {
  display: flex;
  align-items: center;
  gap: 16px;
  background: #F8F4FF;
  padding: 16px;
  border-radius: 24px;
  margin-bottom: 24px;
}

.stats-icon-box {
  width: 48px;
  height: 48px;
  background: #7C4DFF;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-big-num {
  font-size: 24px;
  font-weight: 900;
  color: #FFFFFF;
  font-style: italic;
  line-height: 1;
}

.stats-text {
  flex: 1;
}

.stats-label {
  display: block;
  font-size: 14px;
  font-weight: 700;
  color: #1A1A1A;
}

.stats-sub {
  display: block;
  font-size: 10px;
  color: #999;
  text-transform: uppercase;
  letter-spacing: 1px;
  margin-top: 2px;
}

/* ======== 空态 ======== */
.list-empty {
  text-align: center;
  padding: 60px 0;
  color: #B0A0D0;
  font-size: 14px;
}

/* ======== 双列瀑布流 ======== */
.card-grid {
  display: flex;
  gap: 16px;
}

.card-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.card-item {
  background: #FFFFFF;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid #F0F0F0;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}

/* 封面 */
.card-cover-wrap {
  position: relative;
  overflow: hidden;
}
.card-cover { width: 100%; display: block; }
.card-cover-empty { width: 100%; height: 120px; background: #F5F0FF; }
.card-star {
  position: absolute;
  top: 8px; right: 8px;
  width: 28px; height: 28px;
  background: rgba(0,0,0,0.15);
  backdrop-filter: blur(4px);
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
}

/* 信息 */
.card-info {
  padding: 12px;
}

.card-title {
  display: block;
  font-size: 13px;
  font-weight: 700;
  color: #1A1A1A;
  line-height: 1.4;
  margin-bottom: 8px;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-author-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.card-avatar-empty {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  background: #E0E0E0;
  flex-shrink: 0;
}

.card-name {
  font-size: 10px;
  color: #999;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-likes {
  font-size: 10px;
  color: #7C4DFF;
  font-weight: 700;
}
