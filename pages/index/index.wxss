/* pages/index/index.wxss — 首页（Stitch ⭐ 原型重做） */
page {
  background-color: #FFFFFF;
}

/* ======== 导航栏 ======== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding-left: 16px;
  background-color: #8A4DFF;
  box-sizing: content-box;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 8px;
}

.nav-icon {
  width: 48rpx;
  height: 48rpx;
  background: #FFFFFF;
  border-radius: 50%;
  padding: 4rpx;
  box-sizing: border-box;
  display: block;
}

.nav-title {
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: -0.5px;
}

.nav-right {
  display: flex;
  align-items: center;
  min-width: 36px;
}

.nav-search-btn {
  font-size: 20px;
  line-height: 1;
  color: #FFFFFF;
}

/* ======== 搜索栏 ======== */
.search-bar {
  display: flex;
  align-items: center;
  margin: 8px 16px 6px;
  padding: 10px 16px;
  background-color: #F5F0FF;
  border-radius: 24px;
  border: 1px solid rgba(138,77,255,0.08);
}

.search-icon {
  font-size: 16px;
  color: #8A4DFF;
  margin-right: 8px;
  line-height: 1;
}

.search-input {
  flex: 1;
  font-size: 14px;
  color: #333;
  background: transparent;
  border: none;
  outline: none;
  height: 22px;
  line-height: 22px;
}

.search-placeholder {
  font-size: 14px;
  color: #999999;
  font-weight: 400;
}

/* ======== 模式切换（高保真原型） ======== */
.mode-wrap {
  display: flex;
  justify-content: center;
  padding: 0 16px;
  margin-bottom: 8px;
}

.mode-switch {
  position: relative;
  display: flex;
  width: 100%;
  height: 64rpx;
  background: #F5F0FF;
  border-radius: 32rpx;
  padding: 0;
  overflow: hidden;
}

.mode-slider {
  position: absolute;
  top: 0;
  left: 0;
  width: 50%;
  height: 100%;
  background: #7C4DFF;
  border-radius: 32rpx;
  transition: transform 0.3s ease;
  z-index: 1;
}

.mode-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: #B0A0D0;
  position: relative;
  z-index: 2;
  background: transparent;
  transition: color 0.3s ease;
}

.mode-btn.active {
  background: transparent;
  color: #FFFFFF;
}

.mode-icon {
  font-size: 14px;
  line-height: 1;
}

.mode-label {
  font-size: 13px;
  font-weight: 600;
  line-height: 1;
}

/* ======== 内容列表容器 ======== */
.content-scroll {
  height: calc(100vh - 88px);
  padding-bottom: calc(56px + env(safe-area-inset-bottom) + 20px);
}

/* ======== 胶片模式（21:9 电影感卡片流） ======== */
.film-cards {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.film-card {
  position: relative;
  width: 100%;
  aspect-ratio: 21 / 9;
  overflow: hidden;
}

.film-cover {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.film-cover-empty {
  background-color: #F5F0FF;
}

/* 渐变遮罩 */
.film-scrim {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 70%;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.35) 45%, transparent 100%);
  pointer-events: none;
  z-index: 1;
}

/* 信息叠压层 */
.film-overlay {
  position: absolute;
  bottom: 12px;
  left: 16px;
  right: 16px;
  z-index: 2;
}

/* 作者行 */
.film-author {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}

.film-avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.8);
  flex-shrink: 0;
}

.film-avatar-empty {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  flex-shrink: 0;
}

.film-author-name {
  font-size: 12px;
  color: #FFFFFF;
  font-weight: 500;
  text-shadow: 0 1px 4px rgba(0,0,0,0.6);
  max-width: 140px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 标题 */
.film-title {
  display: block;
  font-size: 18px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  margin-bottom: 4px;
  text-shadow: 0 1px 5px rgba(0,0,0,0.7);
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* 元信息 */
.film-meta {
  display: block;
  font-size: 12px;
  color: rgba(255,255,255,0.8);
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
}

/* 点赞数 */
.film-likes {
  position: absolute;
  bottom: 14px;
  right: 16px;
  font-size: 12px;
  color: #FFB300;
  font-weight: 500;
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  z-index: 2;
}

/* ======== 卡片模式（双列瀑布流） ======== */
.card-grid {
  display: flex;
  gap: 3px;
  padding: 0 3px;
}

.card-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3px;
}

.card-item {
  position: relative;
  width: 100%;
  height: 480rpx;
  overflow: hidden;
  background: #F5F0FF;
}

.card-img {
  width: 100%;
  height: 100%;
  display: block;
}

.card-img-empty {
  width: 100%;
  height: 100%;
  background: #F5F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 渐变遮罩 — 底部深 → 顶透 */
.card-scrim {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 60%;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.40) 35%, rgba(0,0,0,0.10) 60%, transparent 100%);
  pointer-events: none;
}

.card-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 12rpx 14rpx 12rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
}

/* ======== 标题栏（卡片顶部） ======== */
.card-title-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  padding: 32rpx 12rpx 24rpx;
  z-index: 2;
  background: linear-gradient(to bottom, rgba(0,0,0,0.55) 0%, transparent 100%);
  pointer-events: none;
}

.card-title {
  display: block;
  font-size: 15px;
  font-weight: 700;
  color: #FFFFFF;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  letter-spacing: -0.3px;
  word-break: break-word;
}

/* ======== 底部信息行 ======== */
.card-bottom-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.card-author-row {
  display: flex;
  align-items: center;
  gap: 5rpx;
}

.card-avatar {
  width: 26px;
  height: 26px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.75);
  flex-shrink: 0;
  background: rgba(255,255,255,0.1);
}

.card-author-name {
  font-size: 12px;
  color: rgba(255,255,255,0.9);
  text-shadow: 0 1px 4px rgba(0,0,0,0.5);
  max-width: 90px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-weight: 500;
}

.card-meta-right {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.card-days {
  font-size: 11px;
  color: rgba(255,255,255,0.85);
  font-weight: 500;
  text-shadow: 0 1px 4px rgba(0,0,0,0.45);
}

.card-likes {
  font-size: 11px;
  color: #FFCC33;
  font-weight: 600;
  text-shadow: 0 1px 4px rgba(0,0,0,0.45);
}

/* ======== 空状态 ======== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80px 0;
  gap: 12px;
}

.empty-icon {
  font-size: 48px;
  color: #8A4DFF;
  opacity: 0.5;
}

.empty-text {
  font-size: 14px;
  color: #999999;
}

.empty-action {
  margin-top: 8px;
  padding: 10px 32px;
  background: #7C4DFF;
  border-radius: 24px;
}

.empty-action-text {
  font-size: 14px;
  color: #FFFFFF;
  font-weight: 600;
}

/* 加载 */
.loading-bar {
  text-align: center;
  padding: 20px 0;
  color: #999999;
  font-size: 12px;
}
