/* pages/publish/publish.wxss — 发布页（电影感旅行日记 zip 风格） */
page {
  background-color: #FFFFFF;
}

/* ======== 顶部操作栏 ======== */
.publish-header {
  display: flex; align-items: center;
  height: 44px; padding: 0 16px;
  background: #FFFFFF;
  border-bottom: 1px solid #F0F0F0;
  box-sizing: content-box;
  position: sticky; top: 0; z-index: 100;
}
.header-close {
  font-size: 20px; color: #1A1A1A;
  width: 32px; height: 32px;
  display: flex; align-items: center; justify-content: center;
}
.header-center {
  flex: 1; display: flex; align-items: center;
}
.header-title {
  font-size: 17px; font-weight: 700; color: #1A1A1A;
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.header-actions {
  display: flex; align-items: center; gap: 8px;
}
.header-publish {
  padding: 6px 16px; background: #8A4DFF; color: #FFFFFF;
  border-radius: 20px; font-size: 13px;
  white-space: nowrap;
}
.header-publish.is-loading {
  background: #CCCCCC; pointer-events: none;
}

/* ======== 草稿指示条 ======== */
.draft-indicator {
  display: flex; align-items: center; gap: 6px;
  padding: 6px 24px;
  background: #F9F7FF;
  border-bottom: 1px solid #F0F0F0;
}
.draft-icon { font-size: 13px; }
.draft-label { font-size: 12px; color: #7C4DFF; font-weight: 600; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.draft-time { font-size: 11px; color: #999; flex-shrink: 0; }

/* ======== 正文编辑区 ======== */
.publish-body {
  height: calc(100vh - 44px);
  padding-bottom: 180rpx;
}
.loading { text-align: center; padding: 60px 0; color: #999; font-size: 14px; }

/* ======== 封面选择区（21:9） ======== */
/* ======== 封面区（无照片占位） ======== */
.cover-placeholder {
  height: 240rpx;
  background: linear-gradient(135deg, #F5F0FF 0%, #E8DEFF 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 0 48rpx;
}
.cover-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(138,77,255,0.15);
  margin-bottom: 16rpx;
}
.cover-icon {
  width: 32rpx;
  height: 32rpx;
}
.cover-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #8A4DFF;
}
.cover-hint {
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* ======== 封面区（有照片） ======== */
.cover-display {
  position: relative;
  width: 100%;
  aspect-ratio: 16/9;
}
.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}
.change-cover-btn {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  background: rgba(255,255,255,0.9);
  border: 1rpx solid #8A4DFF;
  color: #8A4DFF;
  font-size: 22rpx;
  border-radius: 24rpx;
  padding: 8rpx 16rpx;
}

/* ======== 标题区 ======== */
.title-section {
  margin: 24px 24px 0;
  padding-bottom: 12px;
  border-bottom: 1px solid #F0F0F0;
}
.title-input {
  width: 100%;
  font-size: 24px; font-weight: 700; color: #1A1A1A;
  border: none; background: transparent; padding: 0;
}

/* ======== 基础信息卡片 ======== */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin: 16px 24px;
}
.info-card {
  background: #F5F0FF;
  border-radius: 16px;
  padding: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
}
.info-icon { font-size: 20px; line-height: 1; color: #7C4DFF; }
.info-text { display: flex; flex-direction: column; gap: 2px; flex: 1; }
.info-label { font-size: 10px; color: #999999; }
.info-value { font-size: 13px; font-weight: 700; color: #1A1A1A; border: none; background: transparent; padding: 0; }
.info-placeholder { font-size: 13px; font-weight: 700; color: #CCC; }
.date-pickers { display: flex; align-items: center; gap: 4px; }
.date-sep { font-size: 12px; color: #CCC; }
.trip-days-wrap { text-align: center; padding: 0 24px 8px; }
.trip-days-text { font-size: 13px; color: #7C4DFF; font-weight: 700; }

/* ======== 时间轴 ======== */
.timeline { padding: 24px 24px 0; position: relative; }
.timeline-line {
  position: absolute; left: 43px; top: 20px; bottom: 20px;
  width: 2px; background: rgba(124,77,255,0.12);
}
.timeline-nodes { display: flex; flex-direction: column; gap: 32px; }
.timeline-node { display: flex; gap: 16px; position: relative; }
.timeline-marker { flex-shrink: 0; width: 32px; display: flex; justify-content: center; padding-top: 8px; }
.marker-dot {
  width: 32px; height: 32px; background: #7C4DFF; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  box-shadow: 0 2px 8px rgba(124,77,255,0.3); z-index: 1; border: 4px solid #FFFFFF;
}
.marker-num { font-size: 12px; font-weight: 700; color: #FFFFFF; }
.timeline-card {
  flex: 1; background: #FFFFFF; border-radius: 16px; padding: 16px;
  box-shadow: 0 2px 8px rgba(0,0,0,0.04); border: 1px solid #F0F0F0; position: relative;
}
.card-top { display: flex; justify-content: space-between; align-items: center; margin-top: 14rpx; margin-bottom: 10px; }
.card-title { font-size: 14px; font-weight: 700; color: #1A1A1A; }
.card-del { font-size: 16px; color: #999; padding: 4px; }
.card-photo { width: 100%; aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; object-fit: cover; display: block; background: #F5F0FF; margin-bottom: 10px; }
.card-cover-badge { position: absolute; top: 12px; left: 12px; padding: 2px 8px; background: #8A4DFF; color: #FFF; font-size: 10px; border-radius: 4px; }
.card-caption { width: 100%; font-size: 12px; color: #999; border: none; background: transparent; padding: 0; height: 48px; line-height: 1.5; resize: none; }

/* 添加节点按钮 */
.add-node { display: flex; justify-content: center; padding: 24px 0; }
.add-node-btn {
  display: flex; align-items: center; gap: 8px;
  background: #7C4DFF; color: #FFFFFF;
  padding: 12px 28px; border-radius: 28px; font-size: 14px; font-weight: 700;
  box-shadow: 0 4px 12px rgba(124,77,255,0.3);
}
.add-node-icon { font-size: 20px; font-weight: 300; line-height: 1; }
.add-node-text { font-size: 14px; }

.description-section {
  margin: 24rpx 32rpx;
  padding: 24rpx;
  background: #F8F6FE;
  border-radius: 16rpx;
}
.description-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #1A1A1A;
  line-height: 1.6;
}
.description-placeholder {
  color: #999;
  font-size: 26rpx;
}
.bottom-spacer { height: 20px; }

/* ======== 底部操作栏 ======== */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  background: #fff;
  border-top: 1rpx solid #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
  height: 100rpx;
}
.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
  position: relative;
  flex: 1;
}
.bottom-btn-icon {
  width: 44rpx;
  height: 44rpx;
}
.bottom-btn-text {
  font-size: 22rpx;
  color: #999;
}
.draft-badge {
  position: absolute;
  top: -4rpx;
  right: 50%;
  margin-right: -28rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #FF4444;
}
.save-draft-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #FFFFFF;
  border: 2rpx solid #8A4DFF;
  border-radius: 32rpx;
  padding: 14rpx 28rpx;
  color: #8A4DFF;
  font-size: 26rpx;
  flex: none;
}
.sd-icon {
  width: 28rpx;
  height: 28rpx;
}
.sd-text {
  color: #8A4DFF;
  font-size: 26rpx;
}

/* ======== 预览遮罩（页面内全屏 overlay） ======== */
.preview-overlay {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 3000;
  background: #FFFFFF;
  transform: translateY(100%);
  transition: transform 0.3s ease;
  overflow: hidden;
}
.preview-overlay.show { transform: translateY(0); }
.preview-header {
  position: sticky; top: 0; z-index: 10;
  background: #FFFFFF; border-bottom: 1px solid #F0F0F0;
  padding: 10px 16px; padding-bottom: 10px;
  display: flex; align-items: center;
}
.preview-back { font-size: 15px; color: #7C4DFF; font-weight: 600; padding: 4px 0; }
.preview-body { height: calc(100vh - 48px); background: #F9F9F9; }

.pv-cover { position: relative; width: 100%; height: 320px; overflow: hidden; }
.pv-cover-img { width: 100%; height: 100%; object-fit: cover; }
.pv-cover-grad { position: absolute; inset: 0; background: linear-gradient(to top, rgba(0,0,0,0.5) 0%, transparent 60%); }
.pv-cover-text { position: absolute; bottom: 32px; left: 24px; right: 24px; }
.pv-title { font-size: 26px; font-weight: 800; color: #FFF; text-shadow: 0 2px 8px rgba(0,0,0,0.3); }

.pv-content { padding: 24px; }
.pv-meta { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 20px; padding-bottom: 16px; border-bottom: 1px solid #E8E8E8; }
.pv-meta-item { font-size: 13px; color: #666; font-weight: 500; }
.pv-desc { background: #FFF; padding: 16px; border-radius: 12px; margin-bottom: 20px; font-size: 14px; color: #333; line-height: 1.6; box-shadow: 0 1px 4px rgba(0,0,0,0.04); }

.pv-timeline { position: relative; padding-left: 24px; }
.pv-node { position: relative; margin-bottom: 24px; }
.pv-node-line { position: absolute; left: -24px; top: 0; bottom: 0; width: 2px; background: #E0D8FF; }
.pv-node-dot { position: absolute; left: -28px; top: 8px; width: 10px; height: 10px; background: #7C4DFF; border-radius: 50%; border: 2px solid #FFF; box-shadow: 0 0 0 1px #E0D8FF; }
.pv-card { background: #FFF; border-radius: 12px; overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.pv-card-img { width: 100%; display: block; }
.pv-card-desc { display: block; padding: 12px 16px; font-size: 13px; color: #555; line-height: 1.5; }
.pv-spacer { height: 60px; }
