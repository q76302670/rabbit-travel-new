/* pages/poster/index.wxss — 海报生成页（新 zip 风格） */
page {
  background-color: #F5F0FF;
}

/* ======== 导航栏 ======== */
.page-header {
  display: flex; align-items: center;
  height: 44px; box-sizing: content-box;
  padding-left: 16px; background: #8A4DFF;
}
.header-back { font-size: 20px; color: #FFFFFF; margin-right: 12px; line-height: 1; }
.header-title { flex: 1; font-size: 18px; font-weight: 700; color: #FFFFFF; }
.header-spacer { width: 40px; }

/* ======== 正文 ======== */
.poster-body {
  padding: 24px 16px;
  padding-bottom: calc(24px + env(safe-area-inset-bottom));
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ======== 海报预览卡片 ======== */
.poster-card {
  width: 100%;
  border-radius: 24px;
  overflow: hidden;
  box-shadow: 0 12px 48px -12px rgba(124,77,255,0.4);
}

.poster-preview {
  width: 100%;
  aspect-ratio: 3 / 4;
  position: relative;
  overflow: hidden;
  background-size: cover;
  background-position: center;
  background-color: #F0E8F8;
}

.poster-scrim {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0) 60%);
}

/* 信息区 */
.poster-info {
  position: absolute;
  bottom: 32px;
  left: 32px;
  right: 32px;
  z-index: 2;
}

.poster-date {
  font-size: 10px;
  color: rgba(255,255,255,0.7);
  letter-spacing: 2px;
  margin-bottom: 8px;
  font-style: italic;
}

.poster-title {
  display: block;
  font-size: 36px;
  font-weight: 900;
  color: #FFFFFF;
  text-transform: uppercase;
  letter-spacing: -1px;
  font-style: italic;
  line-height: 1;
  margin-bottom: 12px;
}

.poster-location-badge {
  display: flex;
  align-items: center;
  gap: 4px;
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(8px);
  border-radius: 20px;
  padding: 4px 12px;
  border: 1px solid rgba(255,255,255,0.15);
  width: fit-content;
  margin-bottom: 12px;
}

.loc-icon { font-size: 10px; }
.loc-text {
  font-size: 9px;
  color: rgba(255,255,255,0.8);
  font-weight: 500;
}

.poster-quote {
  position: relative;
  padding-left: 12px;
  border-left: 2px solid rgba(138,77,255,0.5);
}

.quote-text {
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  line-height: 1.5;
  font-weight: 300;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 品牌水印 */
.poster-watermark {
  position: absolute;
  top: 24px;
  right: 24px;
  display: flex;
  align-items: center;
  gap: 6px;
  opacity: 0.6;
  z-index: 2;
}

.wm-icon {
  font-size: 12px;
  color: #FFFFFF;
}

.wm-text {
  font-size: 12px;
  color: #FFFFFF;
  font-style: italic;
  font-weight: 400;
}

/* 空态 */
.poster-empty {
  width: 100%;
  aspect-ratio: 3 / 4;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F0E8F8;
  border-radius: 24px;
  color: #999;
}

/* ======== 节点选择 ======== */
.node-section {
  width: 100%;
  margin-top: 40px;
}

.node-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 16px;
  padding: 0 4px;
}

.node-title {
  font-size: 14px; font-weight: 700; color: #1A1A1A;
}

.node-count {
  font-size: 10px; color: #7C4DFF;
  padding: 2px 6px;
  background: rgba(124,77,255,0.1);
  border-radius: 4px;
}

.node-scroll {
  display: flex;
  gap: 16px;
  white-space: nowrap;
  padding-bottom: 8px;
}

.node-thumb {
  flex-shrink: 0;
  width: 80px;
  height: 80px;
  border-radius: 16px;
  overflow: hidden;
  position: relative;
  opacity: 0.6;
  filter: grayscale(1);
  transition: all 0.2s ease;
}

.node-thumb.active {
  opacity: 1;
  filter: grayscale(0);
  box-shadow: 0 0 0 2px #7C4DFF, 0 0 0 5px #FFFFFF;
}

.thumb-img {
  width: 100%; height: 100%;
  object-fit: cover; display: block;
}

/* ======== 底部操作按钮 ======== */
.poster-actions {
  position: fixed;
  bottom: 104px;
  left: 24px;
  right: 24px;
  display: flex;
  gap: 12px;
  z-index: 10;
}

.poster-btn {
  flex: 1;
  height: 56px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16px;
  font-size: 14px; font-weight: 700;
}

.poster-btn-outline {
  background: #FFFFFF;
  color: #7C4DFF;
  box-shadow: 0 4px 16px rgba(0,0,0,0.08);
}

.poster-btn-primary {
  flex: 1.5;
  background: #7C4DFF;
  color: #FFFFFF;
  box-shadow: 0 8px 24px rgba(124,77,255,0.35);
}
