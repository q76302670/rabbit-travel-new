<!-- pages/journal/detail.wxml — 游记详情页（像素级还原） -->
<view class="page-detail">
  <!-- 顶部导航栏 -->
  <view class="detail-nav" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-left">
      <text class="nav-back" bindtap="goBack">‹</text>
    </view>
    <text class="nav-title">游记详情</text>
    <view class="nav-right">
      <image class="nav-icon" src="/static/icons/share.svg" mode="aspectFit" />
      <image class="nav-icon" src="/static/icons/more-horiz.svg" mode="aspectFit" />
    </view>
  </view>

  <!-- 封面区（21:9） -->
  <view class="detail-cover" wx:if="{{journal}}">
    <image class="cover-img" src="{{journal.cover}}" mode="aspectFill" binderror="handleImageError" data-imgfield="journal.cover" wx:if="{{journal.cover}}" />
    <view class="cover-img-placeholder" wx:else></view>
    <view class="cover-gradient"></view>
    <view class="cover-info">
      <text class="cover-title">{{journal.title}}</text>
      <view class="cover-author" bindtap="goToUserProfile">
        <image class="cover-avatar" src="{{journal.author_avatar}}" mode="aspectFill" binderror="handleImageError" data-imgfield="journal.author_avatar" wx:if="{{journal.author_avatar}}" />
        <view class="cover-avatar-placeholder" wx:else></view>
        <text class="cover-nickname">{{journal.author_name || '旅行者'}}</text>
        <text class="cover-date" wx:if="{{journal._pubDate}}">{{journal._pubDate}}</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{loading}}" class="detail-loading"><text>加载中...</text></view>

  <!-- 正文区 -->
  <view class="detail-body" wx:if="{{journal}}">
    <!-- 行程信息卡（3栏） -->
    <view class="trip-info-bar">
      <view class="info-cell">
        <view class="info-icon-wrap">
          <image class="info-icon-img" src="/static/icons/location-purple.svg" mode="aspectFit" />
        </view>
        <view class="info-text">
          <text class="info-label">目的地</text>
          <text class="info-value">{{journal.destination || '-'}}</text>
        </view>
      </view>
      <view class="info-divider"></view>
      <view class="info-cell">
        <view class="info-icon-wrap">
          <image class="info-icon-img" src="/static/icons/calendar-purple.svg" mode="aspectFit" />
        </view>
        <view class="info-text">
          <text class="info-label">行程时长</text>
          <text class="info-value">{{journal.trip_days || '-'}}天行程</text>
        </view>
      </view>
      <view class="info-divider"></view>
      <view class="info-cell">
        <view class="info-icon-wrap">
          <image class="info-icon-img" src="/static/icons/hiking-purple.svg" mode="aspectFit" />
        </view>
        <view class="info-text">
          <text class="info-label">游玩类型</text>
          <text class="info-value">等待上线</text>
        </view>
      </view>
    </view>

    <!-- 游记说明 -->
    <view class="detail-intro" wx:if="{{journal.description}}">
      <text>{{journal.description}}</text>
    </view>

    <!-- 地图轨迹区 -->
    <view class="detail-map-section-new" wx:if="{{hasGps}}">
      <view class="map-route-badge">
        <image class="map-route-icon" src="/static/icons/map-purple.svg" mode="aspectFit" />
        <text class="map-route-text">路线：{{journal.title}}</text>
      </view>
      <map class="detail-map-new" latitude="{{mapCenter.lat}}" longitude="{{mapCenter.lng}}" scale="12" markers="{{mapMarkers}}" />
    </view>

    <!-- 节点时间线 -->
    <view class="timeline-wrap" wx:if="{{photos && photos.length > 0}}">
      <view class="timeline-line"></view>
      <view class="timeline-node" wx:for="{{photos}}" wx:key="_id" data-index="{{index}}">
        <view class="timeline-dot"></view>
        <view class="node-header">
          <text class="node-day">第{{index + 1}}天</text>
          <text class="node-time-place">{{item.nodeInfo}}</text>
        </view>
        <view class="node-card">
          <image class="node-img" src="{{item.url}}" mode="widthFix" binderror="handleImageError" data-idx="{{index}}" data-imglist="photos" data-imgfield="url" data-imgidfield="_id" bindtap="previewImage" wx:if="{{item.url}}" />
          <view class="node-img-placeholder" wx:else></view>
          <text class="node-desc" wx:if="{{item.description}}">{{item.description}}</text>
          <!-- 节点底部按钮：点赞 + 评论 -->
          <view class="node-actions">
            <view class="node-action-btn" bindtap="toggleNodeLike" data-nodeid="{{item._id}}" data-index="{{index}}">
              <image class="node-action-icon" src="/static/icons/{{item.isLiked ? 'heart-fill' : 'heart-outline'}}.svg" mode="aspectFit" />
              <text class="node-action-count">{{item.likeCount || item.like_count || 0}}</text>
            </view>
            <view class="node-action-btn" bindtap="toggleNodeComments" data-nodeid="{{item._id}}">
              <image class="node-action-icon" src="/static/icons/comment.svg" mode="aspectFit" />
              <text class="node-action-count">{{item.nodeCommentCount || 0}}</text>
            </view>
          </view>

          <!-- 展开的节点评论区 -->
          <view wx:if="{{expandedNodeMap[item._id]}}" class="node-comments-wrap">
            <view wx:if="{{!nodeCommentsMap[item._id] || nodeCommentsMap[item._id].length === 0}}" class="nc-empty">
              还没有评论
            </view>
            <view wx:for="{{nodeCommentsMap[item._id]}}" wx:for-item="nc" wx:key="_id" class="node-comment-item">
              <image class="nc-avatar" src="{{nc.author_avatar}}" mode="aspectFill" binderror="handleImageError" wx:if="{{nc.author_avatar}}" />
              <view class="avatar-placeholder avatar-placeholder--xs" wx:else>🐾</view>
              <view class="nc-body">
                <text class="nc-name">{{nc.author_name}}</text>
                <text class="nc-content">{{nc.content}}</text>
                <view class="nc-meta">
                  <text class="nc-time">{{nc.timeText}}</text>
                  <text class="nc-reply" data-commentid="{{nc._id}}" data-userid="{{nc.author_id}}" data-username="{{nc.author_name}}" bindtap="onTapReply">回复</text>
                </view>
                <!-- 二级回复 -->
                <view wx:if="{{nc.repliesCount > 0}}" class="nc-replies">
                  <view wx:for="{{nc.replies}}" wx:for-item="r" wx:key="_id" class="nc-reply-item">
                    <text class="nc-reply-name">{{r.author_name}}</text>
                    <text wx:if="{{r.replyToUserName}}"> 回复 @{{r.replyToUserName}}</text>
                    <text>：{{r.content}}</text>
                  </view>
                </view>
              </view>
            </view>
            <view class="add-node-comment-btn" bindtap="openNodeCommentInput" data-nodeid="{{item._id}}">
              + 评论这张照片
            </view>
          </view>
        </view>
      </view>
    </view>

    <!-- 评论区（支持一级评论 + 二级回复） -->
    <view class="detail-comments">
      <text class="comments-title">评论 · {{commentCount}}</text>
      <view wx:if="{{comments.length === 0}}" class="comments-empty">
        <text>还没有评论，来说点什么吧</text>
      </view>
      <view class="comment-card" wx:for="{{comments}}" wx:key="_id">
        <!-- 一级评论 -->
        <view class="comment-main">
          <image class="comment-avatar" src="{{item.author_avatar}}" mode="aspectFill" binderror="handleImageError" data-imgfield="author_avatar" wx:if="{{item.author_avatar}}" />
          <view class="avatar-placeholder avatar-placeholder--xs" wx:else>🐾</view>
          <view class="comment-body">
            <text class="comment-name">{{item.author_name}}</text>
            <text class="comment-content">{{item.content}}</text>
            <view class="comment-meta">
              <text class="comment-time">{{item.timeText}}</text>
              <text class="comment-reply-btn" data-commentid="{{item._id}}" data-userid="{{item.author_id}}" data-username="{{item.author_name}}" bindtap="onTapReply">回复</text>
              <text class="comment-del" wx:if="{{item.openid === currentUserId || item.author_id === currentUserId}}" data-id="{{item._id}}" bindtap="deleteCloudComment">删除</text>
            </view>
          </view>
        </view>

        <!-- 二级回复区 -->
        <view wx:if="{{item.repliesCount > 0}}" class="replies-wrap">
          <!-- 折叠态 -->
          <view wx:if="{{!expandedRepliesMap[item._id]}}" class="replies-toggle" data-commentid="{{item._id}}" bindtap="toggleRepliesExpand">
            查看 {{item.repliesCount}} 条回复 ›
          </view>
          <!-- 展开态 -->
          <view wx:else>
            <view wx:for="{{item.replies}}" wx:for-item="reply" wx:key="_id" class="reply-item">
              <image class="reply-avatar" src="{{reply.author_avatar}}" mode="aspectFill" binderror="handleImageError" wx:if="{{reply.author_avatar}}" />
              <view class="avatar-placeholder avatar-placeholder--xs" wx:else>🐾</view>
              <view class="reply-body">
                <text class="reply-name">{{reply.author_name}}</text>
                <text wx:if="{{reply.replyToUserName}}" class="reply-target"> 回复 @{{reply.replyToUserName}}</text>
                <text class="reply-content">：{{reply.content}}</text>
                <view class="reply-meta">
                  <text class="reply-time">{{reply.timeText || reply._time}}</text>
                  <text class="reply-action" data-commentid="{{item._id}}" data-userid="{{reply.author_id}}" data-username="{{reply.author_name}}" bindtap="onTapReply">回复</text>
                </view>
              </view>
            </view>
            <view class="replies-toggle" data-commentid="{{item._id}}" bindtap="toggleRepliesExpand">收起</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部互动栏 -->
  <view class="bottom-bar" wx:if="{{journal}}">
    <view class="comment-input-wrap">
      <image class="comment-edit-icon" src="/static/icons/edit-note.svg" mode="aspectFit" />
      <input
        class="comment-input"
        placeholder="{{commentInputPlaceholder}}"
        placeholder-class="comment-placeholder"
        value="{{commentInput}}"
        bindinput="onCommentInput"
        bindconfirm="submitCloudComment"
        confirm-type="send"
      />
      <text wx:if="{{replyTarget || nodeCommentTarget}}" class="cancel-reply" bindtap="cancelNodeComment">取消</text>
    </view>
    <view class="action-group">
      <view class="action-btn" bindtap="toggleCloudLike">
        <image class="action-icon" src="/static/icons/heart-fill.svg" mode="aspectFit" wx:if="{{isLiked}}" />
        <image class="action-icon" src="/static/icons/heart-outline.svg" mode="aspectFit" wx:else />
        <text class="action-label like-label">点赞</text>
      </view>
      <view class="action-btn" bindtap="toggleCloudCollect">
        <image class="action-icon" src="/static/icons/star-fill.svg" mode="aspectFit" wx:if="{{isCollected}}" />
        <image class="action-icon" src="/static/icons/star-outline.svg" mode="aspectFit" wx:else />
        <text class="action-label collect-label">收藏</text>
      </view>
      <button class="action-btn share-btn" open-type="share">
        <image class="action-icon" src="/static/icons/ios-share-gray.svg" mode="aspectFit" />
        <text class="action-label share-label">分享</text>
      </button>
    </view>
  </view>
</view>
