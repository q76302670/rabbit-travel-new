/* ========================================
   兔子旅行 — 全局样式
   主色: #8A4DFF  深版: #7C4DFF
   底色: #FFFFFF  辅助: #F5F0FF
   点缀: #FFB300  危险: #FF4444
   主文: #1A1A1A  辅文: #999999
   ======================================== */
page {
  background-color: #FFFFFF;
  color: #1A1A1A;
  --safe-area-bottom: env(safe-area-inset-bottom);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
  font-size: 14px;
  line-height: 1.5;
  box-sizing: border-box;
}

view, text, image, button, input, textarea, scroll-view {
  box-sizing: border-box;
}

/* ======== 全局图片加载失败占位 ======== */
.image-placeholder {
  width: 100%;
  height: 100%;
  background: #F5F0FF;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: inherit;
  overflow: hidden;
}
.placeholder-text {
  color: #8A4DFF;
  font-size: 24rpx;
  opacity: 0.5;
}

/* ======== 统一空状态 ======== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
}
.empty-icon {
  width: 120rpx;
  height: 120rpx;
  background: #F5F0FF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}
.empty-icon-text {
  font-size: 60rpx;
}
.empty-title {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 32rpx;
}
.empty-action-btn {
  background: #8A4DFF;
  color: #fff;
  font-size: 26rpx;
  border-radius: 24rpx;
  padding: 16rpx 48rpx;
}

button {
  padding: 0;
  margin: 0;
  background: none;
  border: none;
  border-radius: 0;
  line-height: inherit;
}

button::after {
  border: none;
}

image {
  display: block;
}

/* ========================================
   图片占位方案 — 全局统一
   背景：品牌浅紫 #F5F0FF
   图标：品牌 paw 🐾
   用于 <image wx:else> 的占位 view
   ======================================== */

/* 通用封面/图片占位 */
.img-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F0FF;
  color: #C8B8E8;
  font-size: 28px;
  overflow: hidden;
}

/* 短封面占位（圆形/正方形） */
.img-placeholder--small {
  font-size: 18px;
}

/* 头像占位（圆形） */
.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(138,77,255,0.15);
  color: #B8A0E0;
  font-size: 24px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
}

/* 小头像占位 */
.avatar-placeholder--sm {
  font-size: 14px;
}

.avatar-placeholder--xs {
  font-size: 10px;
}

/* 海报缩略图占位 */
.placeholder-thumb {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F0E8F8;
  color: #C8B8E8;
  font-size: 16px;
}


/* 全局统一返回键图标 */
.nav-back-icon {
  width: 36rpx;
  height: 36rpx;
  flex-shrink: 0;
}
